---
extends: default

rules:
  line-length:
    max: 120
    level: warning
  comments:
    min-spaces-from-content: 1
  truthy:
    allowed-values: ["true", "false", "on", "off", "yes", "no"]
  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1

ignore: |
  ui/node_modules/
  vendor/
  .git/
