# VisualEyes AI-SRE Configuration
# Copy to .env and fill in your values.

# ── LLM Provider (pick one) ──────────────────────────────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# Groq (fast, free tier)
GROQ_API_KEY=

# OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=

# Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_MODEL=anthropic/claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=

# Mistral
# LLM_PROVIDER=mistral
# LLM_MODEL=mistral/mistral-small-latest
# MISTRAL_API_KEY=

# Ollama (local, no key needed)
# LLM_PROVIDER=ollama
# LLM_MODEL=ollama/llama3.2
# (no API key needed)

# ── Kubernetes ───────────────────────────────────────────────────────────────
K8S_NAMESPACES=default
K8S_SCAN_ALL=false
# KUBECONFIG=/home/user/.kube/config   (auto-detected if not set)

# ── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_ENABLED=true
METRICS_WINDOW=5m

# ── Loki (optional) ──────────────────────────────────────────────────────────
LOKI_URL=http://localhost:3100
LOKI_ENABLED=false

# ── Thresholds ───────────────────────────────────────────────────────────────
CPU_CRITICAL_PCT=90.0
MEMORY_CRITICAL_PCT=90.0
RESTART_CRITICAL_COUNT=10

# ── Safety ───────────────────────────────────────────────────────────────────
DRY_RUN=true
AUTO_REMEDIATE=false

# ── Service ──────────────────────────────────────────────────────────────────
AI_SRE_HOST=0.0.0.0
AI_SRE_PORT=8001
AGENT_TIMEOUT_SECONDS=120
MAX_RETRIES=3
POD_LOG_TAIL_LINES=150
