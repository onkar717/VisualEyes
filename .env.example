# VisualEyes Environment Configuration
# Copy to .env and fill in the values.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
VISUAL_EYES_DATABASE_HOST=localhost
VISUAL_EYES_DATABASE_PORT=5432
VISUAL_EYES_DATABASE_USER=visual_eyes
VISUAL_EYES_DATABASE_PASSWORD=visual_eyes
VISUAL_EYES_DATABASE_DBNAME=visual_eyes
VISUAL_EYES_DATABASE_SSLMODE=disable

# ── AI RCA Engine (optional) ─────────────────────────────────────────────────
# Set ANTHROPIC_API_KEY to enable Claude-powered root cause analysis.
ANTHROPIC_API_KEY=
# VISUAL_EYES_RCA_ENABLED=true
# VISUAL_EYES_RCA_MODEL=claude-sonnet-4-5

# ── Server ────────────────────────────────────────────────────────────────────
VISUAL_EYES_SERVER_PORT=8080
VISUAL_EYES_LOGGING_LEVEL=info
VISUAL_EYES_LOGGING_FORMAT=json

# ── Agent output ─────────────────────────────────────────────────────────────
VISUAL_EYES_OUTPUT_REMOTE_ENDPOINT=http://localhost:8080/api/system-metrics
