# VisualEyes Backend Environment Configuration Example
# Copy this file to .env and adjust values for your backend environment

# Gin framework mode (release for production, debug for development)
GIN_MODE=release

# Server port
PORT=8080

# Host address to bind (optional)
HOST=0.0.0.0

# Configuration file path for agents (if backend launches agents)
VISUAL_EYES_CONFIG=/configs/config.yaml

# Remote endpoint where agents send system metrics
VISUAL_EYES_OUTPUT_REMOTE_ENDPOINT=http://localhost:8080/api/system-metrics

# Optional: Disable specific metric collection (true/false)
VISUAL_EYES_AGENT_DISABLE_HOST_METRICS=false
VISUAL_EYES_AGENT_DISABLE_KUBE_METRICS=false

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# (Add any other backend-specific variables here)
